# GitHub Repository RAG Assistant - Environment Configuration
# Copy this file to .env and fill in real values. Never commit the real .env file.

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Backend server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Comma-separated list of allowed frontend origins for CORS.
# Use "*" only for local development.
ALLOWED_ORIGINS=http://localhost:5173

# Storage paths (relative to project root, or absolute paths)
CHROMA_DB_PATH=data/chroma_db
CLONED_REPOS_PATH=data/repositories/cloned_repos
PROCESSED_CHUNKS_PATH=data/processed_chunks
